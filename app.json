{
  "expo": {
    "name": "WRLD",
    "slug": "wrld-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "wrld",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wrld.app"
    },
    "android": {
      "package": "com.wrld.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
