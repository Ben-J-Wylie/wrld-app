{
  "expo": {
    "name": "WRLD",
    "slug": "wrld",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "wrld",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wrld.app",
      "infoPlist": {
        "NSCameraUsageDescription": "WRLD uses your camera to broadcast live video.",
        "NSMicrophoneUsageDescription": "WRLD uses your microphone to broadcast live audio.",
        "NSLocationWhenInUseUsageDescription": "WRLD uses your location to show nearby streams and tag your broadcast.",
        "NSPhotoLibraryUsageDescription": "WRLD accesses your photos to let you set a profile avatar.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wrld.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#5B8CFF",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "35ab0828-46ac-477f-8ace-453105f6601e"
      }
    },
    "owner": "wrld-organization"
  }
}
