+    return v;
+}
+
+- (dispatch_queue_t)methodQueue {
+    return dispatch_get_main_queue();
+}
+
+RCT_CUSTOM_VIEW_PROPERTY(streamURL, NSString *, WRLDCameraPreviewView) {
+    [view setStreamURL:(json ? [RCTConvert NSString:json] : nil)];
+}
+
