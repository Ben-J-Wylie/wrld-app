+/**
+ * WRLD patch (rotationOverride): a renderer proxy that rewrites each frame's
+ * rotation to a fixed value before forwarding to the real renderer. The WebRTC
+ * camera capturer auto-rotates local-preview frames from UIDevice.orientation,
+ * which janks (180°-spin / wrong settle) in an orientation-locked app. Driving
+ * the rotation from JS (our stable device-orientation) via this proxy gives
+ * clean, deliberate portrait/landscape snapping. overrideRotation < 0 = pass
+ * through unchanged. Only 0/90/180/270 are valid RTCVideoRotation values.
+ */
+@interface WRLDRotationRenderer : NSObject <RTCVideoRenderer>
+@property(nonatomic, weak) id<RTCVideoRenderer> target;
+@property(nonatomic, assign) NSInteger overrideRotation;
+@end
+
+@implementation WRLDRotationRenderer
+- (instancetype)initWithTarget:(id<RTCVideoRenderer>)target {
+    if (self = [super init]) {
+        _target = target;
+        _overrideRotation = -1;
+    }
+    return self;
+}
+- (void)setSize:(CGSize)size {
+    [self.target setSize:size];
+}
+- (void)renderFrame:(RTCVideoFrame *)frame {
+    id<RTCVideoRenderer> t = self.target;
+    if (!t) {
+        return;
+    }
+    if (self.overrideRotation >= 0 && frame != nil &&
+        frame.rotation != (RTCVideoRotation)self.overrideRotation) {
+        frame = [[RTCVideoFrame alloc] initWithBuffer:frame.buffer
+                                             rotation:(RTCVideoRotation)self.overrideRotation
+                                          timeStampNs:frame.timeStampNs];
+    }
+    [t renderFrame:frame];
+}
+@end
