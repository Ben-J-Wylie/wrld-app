+#if !TARGET_OS_TV
+
+#import <UIKit/UIKit.h>
+
+@class WebRTCModule;
+
+/**
+ * WRLD patch (iOS continuous-gimbal preview): renders the LOCAL camera preview
+ * with an AVCaptureVideoPreviewLayer tapped off the WebRTC capturer's existing
+ * AVCaptureSession (the raw camera feed, decoupled from the encoded WebRTC
+ * track) and rotates it continuously so the scene stays vertical at any phone
+ * tilt — the Android behaviour the RTCMTLVideoView discrete path can't match.
+ *
+ * The session is REUSED, never re-opened (one camera = one session). WebRTC
+ * keeps capturing + transmitting on the same session; this view only adds a
+ * preview layer to it. Use this for the local preview only (the remote/viewer
+ * path keeps RTCMTLVideoView).
+ */
+@interface WRLDCameraPreviewView : UIView
+
+@property(nonatomic, weak) WebRTCModule *module;
+
+// React tag of the local MediaStream (same value RTCView's `streamURL` takes).
+- (void)setStreamURL:(NSString *)streamURL;
+// Continuous rotation (degrees) applied to the preview layer. JS owns the sign
+// + base calibration; this view just rotates by this value and cover-scales.
+- (void)setRotationDeg:(CGFloat)deg;
+// Horizontal flip for the front camera (natural selfie).
+- (void)setMirror:(BOOL)mirror;
+
+@end
+
+#endif
diff --git a/node_modules/react-native-webrtc/ios/RCTWebRTC/WRLDCameraPreviewView.m b/node_modules/react-native-webrtc/ios/RCTWebRTC/WRLDCameraPreviewView.m
new file mode 100644
index 0000000..1c641cc
--- /dev/null
+++ b/node_modules/react-native-webrtc/ios/RCTWebRTC/WRLDCameraPreviewView.m
@@ -0,0 +1,220 @@
+#if !TARGET_OS_TV
+
+#import "WRLDCameraPreviewView.h"
+
+#import <AVFoundation/AVFoundation.h>
+#import <QuartzCore/QuartzCore.h>
+
+#import <WebRTC/RTCCameraVideoCapturer.h>
+#import <WebRTC/RTCMediaStream.h>
+#import <WebRTC/RTCVideoTrack.h>
+
+#import "RTCMediaStreamTrack+React.h"
+#import "VideoCaptureController.h"
+#import "WebRTCModule.h"
+
+// Cap on pinch zoom. Device formats report a huge videoMaxZoomFactor (often
+// 100+), but digital zoom past ~8x is unusable mush — clamp to that.
+static const CGFloat kWRLDMaxZoom = 8.0;
+
+@interface WRLDCameraPreviewView ()
+@property(nonatomic, strong) AVCaptureVideoPreviewLayer *previewLayer;
+@property(nonatomic, copy) NSString *currentStreamURL;
+@property(nonatomic, assign) CGFloat rotationDeg;
+@property(nonatomic, assign) BOOL mirror;
+// videoZoomFactor of the active device at the start of the current pinch.
+@property(nonatomic, assign) CGFloat zoomBase;
+@end
+
+@implementation WRLDCameraPreviewView
+
+- (instancetype)init {
+    if (self = [super init]) {
+        self.backgroundColor = [UIColor blackColor];
+        self.clipsToBounds = YES;
+        // Pinch → real camera zoom (AVCaptureDevice.videoZoomFactor), so the
+        // broadcast + buffer zoom too (not a preview-only visual scale).
+        UIPinchGestureRecognizer *pinch =
+            [[UIPinchGestureRecognizer alloc] initWithTarget:self action:@selector(handlePinch:)];
+        [self addGestureRecognizer:pinch];
+    }
+    return self;
+}
+
+- (void)dealloc {
+    [self detach];
+}
+
+#pragma mark - Props
+
+- (void)setStreamURL:(NSString *)streamURL {
+    if (streamURL == _currentStreamURL || [_currentStreamURL isEqualToString:streamURL]) {
+        return;
+    }
+    _currentStreamURL = [streamURL copy];
+
+    if (!streamURL) {
+        [self detach];
+        return;
+    }
+
+    // Resolve stream → first video track → its capture controller → the
+    // RTCCameraVideoCapturer's AVCaptureSession, on the module worker queue
+    // (where the streams live), then attach the preview layer on main.
+    WebRTCModule *module = self.module;
+    NSString *tag = [streamURL copy];
+    dispatch_async(module.workerQueue, ^{
+        RTCMediaStream *stream = [module streamForReactTag:tag];
+        RTCVideoTrack *videoTrack = stream.videoTracks.firstObject;
+        VideoCaptureController *cc = nil;
+        if ([videoTrack.captureController isKindOfClass:[VideoCaptureController class]]) {
+            cc = (VideoCaptureController *)videoTrack.captureController;
+        }
+        AVCaptureSession *session = cc.capturer.captureSession;
+        if (!session) {
+            return;
+        }
+        dispatch_async(dispatch_get_main_queue(), ^{
+            // Stale check: streamURL may have changed while we hopped queues.
+            if (![self->_currentStreamURL isEqualToString:tag]) {
+                return;
+            }
+            [self attachSession:session];
+        });
+    });
+}
+
+- (void)setRotationDeg:(CGFloat)deg {
+    if (_rotationDeg == deg) {
+        return;
+    }
+    _rotationDeg = deg;
+    [self applyTransform];
+}
+
+- (void)setMirror:(BOOL)mirror {
+    if (_mirror == mirror) {
+        return;
+    }
+    _mirror = mirror;
+    [self applyTransform];
+}
+
+#pragma mark - Layer lifecycle
+
+- (void)attachSession:(AVCaptureSession *)session {
+    if (_previewLayer.session == session) {
+        return;
+    }
+    [self detach];
+
+    _previewLayer = [AVCaptureVideoPreviewLayer layerWithSession:session];
+    _previewLayer.videoGravity = AVLayerVideoGravityResizeAspectFill;
+    // Deterministic baseline: portrait. tilt 0 ⟹ upright, so the JS gimbal
+    // angle is a pure counter-rotation of the physical roll.
+    if (_previewLayer.connection.isVideoOrientationSupported) {
+        _previewLayer.connection.videoOrientation = AVCaptureVideoOrientationPortrait;
+    }
+    [self.layer addSublayer:_previewLayer];
+    [self applyLayout];
+}
+
+- (void)detach {
+    [_previewLayer removeFromSuperlayer];
+    _previewLayer = nil;
+}
+
+#pragma mark - Pinch zoom
+
+// The active video AVCaptureDevice behind the session (the WebRTC capturer's
+// camera input). videoZoomFactor lives on the device, so zooming it zooms the
+// captured frames → the broadcast/buffer zoom too, not just this preview.
+- (AVCaptureDevice *)currentVideoDevice {
+    AVCaptureSession *session = _previewLayer.session;
+    for (AVCaptureInput *input in session.inputs) {
+        if ([input isKindOfClass:[AVCaptureDeviceInput class]]) {
+            AVCaptureDevice *device = ((AVCaptureDeviceInput *)input).device;
+            if ([device hasMediaType:AVMediaTypeVideo]) {
+                return device;
+            }
+        }
+    }
+    return nil;
+}
+
+- (void)handlePinch:(UIPinchGestureRecognizer *)g {
+    AVCaptureDevice *device = [self currentVideoDevice];
+    if (!device) {
+        return;
+    }
+    if (g.state == UIGestureRecognizerStateBegan) {
+        _zoomBase = device.videoZoomFactor;
+        return;
+    }
+    if (g.state != UIGestureRecognizerStateChanged) {
+        return;
+    }
+    CGFloat minZoom = device.minAvailableVideoZoomFactor;  // usually 1.0
+    CGFloat maxZoom = MIN(device.activeFormat.videoMaxZoomFactor, kWRLDMaxZoom);
+    CGFloat target = MAX(minZoom, MIN(_zoomBase * g.scale, maxZoom));
+    NSError *err = nil;
+    if ([device lockForConfiguration:&err]) {
+        device.videoZoomFactor = target;
+        [device unlockForConfiguration];
+    }
+}
+
+- (void)layoutSubviews {
+    [super layoutSubviews];
+    [self applyLayout];
+}
+
+#pragma mark - Geometry
+
+- (void)applyLayout {
+    if (!_previewLayer) {
+        return;
+    }
+    [CATransaction begin];
+    [CATransaction setDisableActions:YES];
+    // Reset the transform before sizing so bounds/position aren't measured
+    // through the rotation, then re-apply.
+    _previewLayer.affineTransform = CGAffineTransformIdentity;
+    _previewLayer.bounds = self.bounds;
+    _previewLayer.position = CGPointMake(CGRectGetMidX(self.bounds), CGRectGetMidY(self.bounds));
+    [CATransaction commit];
+    [self applyTransform];
+}
+
+- (void)applyTransform {
+    if (!_previewLayer) {
+        return;
+    }
+    CGFloat W = self.bounds.size.width;
+    CGFloat H = self.bounds.size.height;
+    CGFloat rad = _rotationDeg * M_PI / 180.0;
+
+    // Cover-scale: a W×H layer rotated by θ must grow to keep filling the W×H
+    // frame (otherwise it letterboxes). =1 at 0°, grows with tilt — the same
+    // zoom-with-tilt Android's continuous preview has (expected, not a bug).
+    CGFloat scale = 1.0;
+    if (W > 0 && H > 0) {
+        CGFloat c = fabs(cos(rad));
+        CGFloat s = fabs(sin(rad));
+        scale = MAX((W * c + H * s) / W, (W * s + H * c) / H);
+    }
+
+    // Mirror is innermost (flip the image L-R), then rotate, then cover-scale.
+    // Implicit CA animation off so continuous JS updates track 1:1.
+    CGFloat m = _mirror ? -1.0 : 1.0;
+    CGAffineTransform t = CGAffineTransformScale(CGAffineTransformMakeRotation(rad), scale * m, scale);
+
+    [CATransaction begin];
+    [CATransaction setDisableActions:YES];
+    _previewLayer.affineTransform = t;
+    [CATransaction commit];
+}
+
+@end
+
+#endif
