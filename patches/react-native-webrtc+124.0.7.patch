+#if !TARGET_OS_TV
+
+#import <React/RCTViewManager.h>
+
+#import "WRLDCameraPreviewView.h"
+#import "WebRTCModule.h"
+
+/**
+ * WRLD patch: view manager for the iOS continuous-gimbal local camera preview.
+ * Exposes the native component `WRLDCameraPreview` to JS with `streamURL`,
+ * `rotationDeg` and `mirror` props. See WRLDCameraPreviewView for the why.
+ */
+@interface WRLDCameraPreviewManager : RCTViewManager
+@end
+
+@implementation WRLDCameraPreviewManager
+
+RCT_EXPORT_MODULE()
+
+- (UIView *)view {
+    WRLDCameraPreviewView *v = [[WRLDCameraPreviewView alloc] init];
+    v.module = [self.bridge moduleForName:@"WebRTCModule"];
+    return v;
+}
+
+- (dispatch_queue_t)methodQueue {
+    return dispatch_get_main_queue();
+}
+
+RCT_CUSTOM_VIEW_PROPERTY(streamURL, NSString *, WRLDCameraPreviewView) {
+    [view setStreamURL:(json ? [RCTConvert NSString:json] : nil)];
+}
+
+RCT_CUSTOM_VIEW_PROPERTY(rotationDeg, NSNumber *, WRLDCameraPreviewView) {
+    [view setRotationDeg:(json ? [json floatValue] : 0)];
+}
+
+RCT_CUSTOM_VIEW_PROPERTY(mirror, BOOL, WRLDCameraPreviewView) {
+    [view setMirror:(json ? [json boolValue] : NO)];
+}
+
+@end
+
+#endif
