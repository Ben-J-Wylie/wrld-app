# API
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Clerk — publishable key from https://dashboard.clerk.com → your app → API Keys
# Safe to expose in the client bundle (it's the publishable key, not the secret key).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_

# Mediasoup signaling — wired in Phase 3
EXPO_PUBLIC_MEDIASOUP_WSS_URL=wss://media.wrld.cam

# Mapbox — public token from mapbox.com → Account → Tokens (pk.eyJ1...)
# Safe to expose in client bundle. Secret download token (sk.) goes in EAS secrets only.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# RevenueCat — PUBLIC, platform-specific SDK keys from
# RevenueCat → Project settings → API keys. iOS key starts `appl_`, Android `goog_`.
# Safe to expose in the client bundle. The RevenueCat SECRET key (sk_…) is NOT
# used here — it lives in wrld-backend for webhook verification only.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_

# Feature flags
EXPO_PUBLIC_ENABLE_DEV_TOOLS=true
